---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={`Mapa de Rondon — ${SITE_TITLE}`} description="Mapa interativo dos locais por onde Aparício passou em Mato Grosso e Rondônia." />
		<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
		<style>
			#map {
				height: 600px;
				width: 100%;
				border-radius: var(--radius, 8px);
				border: 1px solid var(--border-light, #ccc);
				z-index: 1; /* Para evitar sobreposição indevida do z-index do Leaflet com o Header */
			}
			/* Estética minimalista/rústica para o popup */
			.leaflet-popup-content-wrapper {
				background: var(--bg-primary, #fff);
				color: var(--text-primary, #333);
				border: 1px solid var(--border-light, #ccc);
				border-radius: var(--radius, 8px);
				box-shadow: 2px 2px 5px rgba(0,0,0,0.15);
			}
			.leaflet-popup-tip {
				background: var(--bg-primary, #fff);
				border: 1px solid var(--border-light, #ccc);
			}
			.leaflet-popup-content a {
				color: var(--accent-primary, #8b4513);
				font-weight: bold;
				text-decoration: none;
			}
			.leaflet-popup-content a:hover {
				text-decoration: underline;
			}
			/* Filtro sépia para manter o tom rústico do blog nos tiles do mapa */
			.leaflet-layer {
				filter: grayscale(30%) sepia(30%) contrast(95%);
			}
		</style>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Ir ao conteúdo principal</a>
		<Header />

		<header class="hero">
			<div class="container hero-inner">
				<h1 style="font-size: clamp(34px, 4.5vw, 56px);">Mapa de Rondon</h1>
				<p class="hero-kicker">
					Um mapa interativo com as andanças e causos de Aparício pelas estradas poeirentas do Mato Grosso e Rondônia.
				</p>
			</div>
		</header>

		<main id="main-content" role="main" class="section section-textured">
			<div class="container reading-width">
				<div id="map"></div>
			</div>
		</main>

		<Footer />

		<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				// Coordenadas aproximadas do centro entre MT e RO
				const map = L.map('map').setView([-11.5, -60.0], 5);

				L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
					maxZoom: 19,
					attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
				}).addTo(map);

				const locations = [
					{
						name: "Cuiabá",
						coords: [-15.6014, -56.0979],
						desc: "A capital mato-grossense, onde Aparício enfrentou os primeiros choques de realidade.",
						link: "/blog/marechal-rondon/"
					},
					{
						name: "Rolim de Moura",
						coords: [-11.7289, -61.7744],
						desc: "A cidade pioneira onde ele desbravou o direito na beira da floresta.",
						link: "/blog/foi-por-ali/"
					},
					{
						name: "Porto Velho",
						coords: [-8.7612, -63.9039],
						desc: "A capital de Rondônia, palco de eleições acirradas da OAB e histórias ribeirinhas.",
						link: "/blog/eleicao-na-oab-ro/"
					},
					{
						name: "Vilhena",
						coords: [-12.7408, -60.1458],
						desc: "O Portal da Amazônia, com causos inusitados de madeireiros e embalsamentos.",
						link: "/blog/o-embalsamento/"
					}
				];

				locations.forEach(loc => {
					L.marker(loc.coords)
						.addTo(map)
						.bindPopup(`
							<div style="font-family: inherit; font-size: 0.95rem;">
								<strong style="font-size: 1.1rem; color: var(--text-primary, #111);">${loc.name}</strong><br>
								<p style="margin: 0.5rem 0;">${loc.desc}</p>
								<a href="${loc.link}">Ler o causo &rarr;</a>
							</div>
						`);
				});
			});
		</script>
	</body>
</html>
