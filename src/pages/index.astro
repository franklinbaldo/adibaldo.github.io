---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const INITIAL_COUNT = 8;

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const recentPosts = posts.slice(1);

const listItems = posts.slice(0, INITIAL_COUNT).map((post, index) => ({
	"@type": "ListItem",
	"position": index + 1,
	"url": new URL(`/blog/${post.id}/`, Astro.site).toString()
}));

const itemListLD = {
	"@context": "https://schema.org",
	"@type": "ItemList",
	"itemListElement": listItems
};
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(itemListLD).replace(/</g, '\\u003c')} />
	</head>
	<body>
		<a href="#main-content" class="skip-link">Ir ao conteúdo principal</a>
		<Header />

		<section class="hero">
			<div class="container hero-inner">
				<h1>{SITE_TITLE}</h1>
				<p class="hero-kicker">{SITE_DESCRIPTION}</p>
				<p class="hero-kicker" style="max-width: 62ch;">
					Um canto pra juntar lembranças e reflexões, sem barulho. Texto bom é texto que respira.
				</p>
				<div class="hero-actions">
					<a class="cta" href="/blog">Ler os textos</a>
					<a class="cta cta-outline" href="/livro">Abrir livro para imprimir</a>
				</div>
			</div>
		</section>

		<main id="main-content">
			{/* ── Featured Article ── */}
			{featuredPost && (
				<section class="section section-textured">
					<div class="container">
						<div class="section-title">
							<h2 style="margin:0;">Destaque</h2>
						</div>

						<article class="featured-card" style="position: relative;">
							<a href={`/blog/${featuredPost.id}/`} style="position: absolute; inset: 0; z-index: 0;" aria-label={`Ler post: ${featuredPost.data.title}`}></a>
							{featuredPost.data.heroImage ? (
								<Image
									class="featured-card-bg"
									src={featuredPost.data.heroImage}
									alt={featuredPost.data.heroImageAlt || `Capa do post ${featuredPost.data.title}`}
									widths={[600, 1200]}
									sizes="(max-width: 620px) 100vw, 1120px"
									loading="eager"
									fetchpriority="high"
								/>
							) : (
								<div class="featured-card-bg" style="background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));" />
							)}
							<div class="featured-card-overlay">
								<div class="tag-row" style="position: relative; z-index: 1;">
									{featuredPost.data.tags?.slice(0, 2).map((t) => (
										<a href={`/tags/${t}`} class="tag" style="text-decoration: none;">{t}</a>
									))}
								</div>
								<h3 style="position: relative; z-index: 1;"><a href={`/blog/${featuredPost.id}/`} style="color: inherit; text-decoration: none;">{featuredPost.data.title}</a></h3>
								<p>{featuredPost.data.description}</p>
								<p class="meta" style="position: relative; z-index: 1;">
									<FormattedDate date={featuredPost.data.pubDate} />
									<span>&bull;</span>
									<span class="reading-time">{Math.max(1, Math.round((featuredPost.body?.split(/\s+/).length || 0) / 200))} min de leitura</span>
								</p>
							</div>
						</article>
					</div>
				</section>
			)}

			{/* ── Posts com paginação ── */}
			<section class="section section-textured">
				<div class="container">
					<div class="section-title">
						<h2 style="margin:0;">Últimas prosas</h2>
						<a href="/blog">Ver todas ({posts.length})</a>
					</div>

					<div class="grid post-grid-home" id="post-grid">
						{recentPosts.map((post, i) => (
							<article
								class="card post-card-home"
								data-index={i}
								style={i >= INITIAL_COUNT - 1 ? 'display:none; position: relative;' : 'position: relative;'}
							>
								<a href={`/blog/${post.id}/`} style="position: absolute; inset: 0; z-index: 0;" aria-label={`Ler post: ${post.data.title}`}></a>
								<div class="post-thumb-home">
									{post.data.heroImage ? (
										<Image
											src={post.data.heroImage}
											alt={post.data.heroImageAlt || `Capa do post ${post.data.title}`}
											widths={[400, 800, 1200]}
											sizes="(max-width: 620px) 100vw, (max-width: 980px) 50vw, 25vw"
										/>
									) : (
										<div class="post-thumb-fallback-home" aria-hidden="true" />
									)}
								</div>
								<div class="post-card-body-home" style="position: relative; z-index: 1;">
									<div class="tag-row" style="position: relative; z-index: 1;">
										{post.data.tags?.slice(0, 1).map((t) => (
											<a href={`/tags/${t}`} class="tag" style="text-decoration: none; position: relative; z-index: 1;">{t}</a>
										))}
										{post.data.placeLabel && <span class="tag">{post.data.placeLabel}</span>}
									</div>
									<h3 class="card-title"><a href={`/blog/${post.id}/`} style="color: inherit; text-decoration: none; position: relative; z-index: 1;">{post.data.title}</a></h3>
									<p class="card-desc">{post.data.description}</p>
									<p class="meta" style="margin:0;">
										<FormattedDate date={post.data.pubDate} />
										<span>&bull;</span>
										<span class="reading-time">{Math.max(1, Math.round((post.body?.split(/\s+/).length || 0) / 200))} min de leitura</span>
									</p>
								</div>
							</article>
						))}
					</div>

					{recentPosts.length >= INITIAL_COUNT && (
						<div class="load-more-wrap">
							<button class="btn-load-more" id="btn-load-more" type="button">
								Carregar mais
							</button>
						</div>
					)}
				</div>
			</section>
		</main>

		<Footer />

		<script>
			const BATCH = 8;
			const btn = document.getElementById('btn-load-more');
			const grid = document.getElementById('post-grid');
			if (btn && grid) {
				btn.addEventListener('click', () => {
					const hidden = Array.from(grid.querySelectorAll('[data-index]')).filter(
						(el) => (el as HTMLElement).style.display === 'none'
					);
					hidden.slice(0, BATCH).forEach((el) => {
						(el as HTMLElement).style.display = '';
					});
					if (hidden.length <= BATCH) btn.style.display = 'none';
				});
			}
		</script>

		<style>
			.hero-actions {
				display: flex;
				gap: var(--space-md);
				flex-wrap: wrap;
			}

			.cta-outline {
				background: transparent;
				color: var(--accent-primary);
				border: 1px solid var(--accent-primary);
			}

			.cta-outline:hover {
				background: var(--accent-primary);
				color: white;
			}

			.post-grid-home {
				grid-template-columns: repeat(4, 1fr);
			}

			.post-card-home {
				padding: 0;
				overflow: hidden;
				min-height: 0;
				transition: transform 0.25s ease, box-shadow 0.25s ease;
			}

			.post-card-home:hover {
				transform: translateY(-3px);
			}

			.post-thumb-home {
				aspect-ratio: 3 / 2;
				overflow: hidden;
				background: var(--tag-bg);
				border-bottom: 1px solid var(--border-light);
			}

			.post-thumb-home :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 0.35s ease;
			}

			.post-card-home:hover .post-thumb-home :global(img) {
				transform: scale(1.04);
			}

			.post-thumb-fallback-home {
				width: 100%;
				height: 100%;
				background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));
			}

			.post-card-body-home {
				padding: var(--space-md);
				display: flex;
				flex-direction: column;
				gap: var(--space-sm);
			}

			.load-more-wrap {
				display: flex;
				justify-content: center;
				margin-top: var(--space-xl);
			}

			.btn-load-more {
				background: var(--accent-primary);
				color: white;
				border: none;
				border-radius: var(--radius);
				padding: var(--space-sm) var(--space-xl);
				font-size: 1rem;
				cursor: pointer;
				transition: background 0.2s;
			}

			.btn-load-more:hover {
				background: var(--accent-hover, #7a5c3a);
			}

			@media (max-width: 980px) {
				.post-grid-home {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 620px) {
				.post-grid-home {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
