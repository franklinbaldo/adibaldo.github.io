---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.svelte';
import PostList from '../components/PostList.svelte';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const INITIAL_COUNT = 8;

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const recentPosts = posts.slice(1);

const listItems = posts.slice(0, INITIAL_COUNT).map((post, index) => ({
	"@type": "ListItem",
	"position": index + 1,
	"url": new URL(`/blog/${post.id}/`, Astro.site).toString()
}));

const itemListLD = {
	"@context": "https://schema.org",
	"@type": "ItemList",
	"itemListElement": listItems
};
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(itemListLD).replace(/</g, '\\u003c')} />
	</head>
	<body>
		<a href="#main-content" class="skip-link">Ir ao conteúdo principal</a>
		<Header client:load currentPath={Astro.url.pathname} />

		<div class="hero" role="region" aria-label="Destaque da página">
			<div class="container hero-inner">
				<h1>{SITE_TITLE}</h1>
				<p class="hero-kicker">{SITE_DESCRIPTION}</p>
				<p class="hero-kicker" style="max-width: 62ch;">
					Arquivos de memórias e contos, focados em texto.
				</p>
				<div class="hero-actions">
					<a class="cta" href="/blog">Ler os textos</a>
					<a class="cta cta-outline" href="/livro">Abrir livro para imprimir</a>
				</div>
			</div>
		</div>

		<main id="main-content" role="main">
			{/* ── Featured Article ── */}
			{featuredPost && (
				<section class="section section-textured">
					<div class="container">
						<div class="section-title">
							<h2 style="margin:0;">Destaque</h2>
						</div>

						<a href={`/blog/${featuredPost.id}/`} class="featured-card">
							{featuredPost.data.heroImage ? (
								<Image
									src={featuredPost.data.heroImage}
									alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
									class="featured-card-bg"
									width={1120}
									height={560}
									widths={[400, 800, 1120]}
									sizes="(max-width: 620px) 100vw, (max-width: 1120px) 100vw, 1120px"
								/>
							) : (
								<div class="featured-card-bg" style="background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));"></div>
							)}
							<div class="featured-card-overlay">
								{featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
									<div class="tag-row">
										<span class="tag">{featuredPost.data.tags[0]}</span>
									</div>
								)}
								<h3>{featuredPost.data.title}</h3>
								<p>{featuredPost.data.description}</p>
								<div class="meta">
									{featuredPost.data.pubDate.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
									{featuredPost.data.place && ` • ${featuredPost.data.placeLabel || featuredPost.data.place}`}
								</div>
							</div>
						</a>
					</div>
				</section>
			)}

			{/* ── Posts com paginação ── */}
			<section class="section section-textured">
				<div class="container">
					<div class="section-title">
						<h2 style="margin:0;">Últimas prosas</h2>
						<a href="/blog">Ver todas ({posts.length})</a>
					</div>

					<PostList posts={recentPosts} client:visible />
				</div>
			</section>
		</main>

		<Footer />

		<style>
			.hero-actions {
				display: flex;
				gap: var(--space-md);
				flex-wrap: wrap;
			}

			.cta-outline {
				background: transparent;
				color: var(--accent-primary);
				border: 1px solid var(--accent-primary);
			}

			.cta-outline:hover {
				background: var(--accent-primary);
				color: white;
			}
		</style>
	</body>
</html>
