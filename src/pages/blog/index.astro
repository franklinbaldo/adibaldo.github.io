---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPosts = posts.length;
const uniqueTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();

const breadcrumbLD = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Início",
			"item": Astro.site?.toString()
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Textos"
		}
	]
};
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={`Textos — ${SITE_TITLE}`} description="Todos os textos do Adi: memórias, causos, ensaios e prosas de diferentes lugares e tempos." />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />
	</head>
	<body>
		<Header />

		<section class="hero">
			<div class="container hero-inner">
				<h1 style="font-size: clamp(34px, 4.5vw, 56px);">Textos</h1>
				<p class="hero-kicker">
					Memórias, causos e ensaios. Escolhe um e vai no passo.
				</p>
			</div>
		</section>

		<main class="section">
			<div class="container">
				<div class="filter-section" style="margin-bottom: var(--space-xl);">
					<p class="meta" id="post-counter" style="margin-bottom: var(--space-md);">
						Mostrando {totalPosts} textos
					</p>
					<ul class="nav-pills">
						<li>
							<button class="nav-pill filter-tag active" data-tag="all">
								Todos
							</button>
						</li>
						{uniqueTags.map((tag) => (
							<li>
								<button class="nav-pill filter-tag" data-tag={tag}>
									{tag}
								</button>
							</li>
						))}
					</ul>
				</div>
				<div class="grid post-grid">
					{posts.map((post) => (
						<a class="card post-card" href={`/blog/${post.id}/`} data-tags={post.data.tags?.join(',') || ''}>
							<div class="post-thumb">
								{post.data.heroImage ? (
									<Image
										src={post.data.heroImage}
										alt={post.data.heroImageAlt || `Capa do post ${post.data.title}`}
										widths={[400, 800, 1200]}
										sizes="(max-width: 620px) 100vw, (max-width: 980px) 50vw, 33vw"
									/>
								) : (
									<div class="post-thumb-fallback" aria-hidden="true" />
								)}
							</div>
							<div class="post-card-body">
								<div class="tag-row">
									{post.data.tags?.slice(0, 1).map((t) => (
										<span class="tag">{t}</span>
									))}
									{post.data.placeLabel && <span class="tag">{post.data.placeLabel}</span>}
								</div>
								<h3 class="card-title">{post.data.title}</h3>
								<p class="card-desc">{post.data.description}</p>
								<p class="meta" style="margin:0;">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</div>
						</a>
					))}
				</div>
			</div>
		</main>

		<Footer />

		<style>
			.post-grid {
				grid-template-columns: repeat(3, 1fr);
			}

			.post-card {
				padding: 0;
				overflow: hidden;
				transition: transform 180ms ease, box-shadow 180ms ease;
			}

			.post-card:hover {
				transform: translateY(-2px);
			}

			.post-thumb {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: var(--tag-bg);
				border-bottom: 1px solid var(--border-light);
			}

			.post-thumb :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 260ms ease;
			}

			.post-card:hover .post-thumb :global(img) {
				transform: scale(1.03);
			}

			.post-thumb-fallback {
				width: 100%;
				height: 100%;
				background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));
			}

			.post-card-body {
				padding: var(--space-md);
				display: flex;
				flex-direction: column;
				gap: var(--space-sm);
			}

			@media (max-width: 980px) {
				.post-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 620px) {
				.post-grid {
					grid-template-columns: 1fr;
				}
			}

			/* Override the default inactive style for buttons */
			.filter-tag.active {
				border-color: var(--accent-primary);
				box-shadow: var(--shadow-card-hover);
				color: var(--accent-primary);
				transform: translateY(-1px);
			}
			.filter-tag {
				cursor: pointer;
			}
		</style>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const buttons = document.querySelectorAll('.filter-tag');
				const cards = document.querySelectorAll('.post-card');
				const counter = document.getElementById('post-counter');

				buttons.forEach((btn) => {
					btn.addEventListener('click', () => {
						// Update active state on buttons
						buttons.forEach((b) => b.classList.remove('active'));
						btn.classList.add('active');

						const selectedTag = btn.getAttribute('data-tag');
						let visibleCount = 0;

						// Filter cards
						cards.forEach((card) => {
							const htmlCard = card as HTMLElement;
							const cardTags = htmlCard.getAttribute('data-tags') || '';
							const tagsArray = cardTags.split(',').map((t) => t.trim());

							if (selectedTag === 'all' || tagsArray.includes(selectedTag)) {
								htmlCard.style.display = '';
								visibleCount++;
							} else {
								htmlCard.style.display = 'none';
							}
						});

						// Update counter text
						if (counter) {
							counter.textContent = `Mostrando ${visibleCount} texto${visibleCount !== 1 ? 's' : ''}`;
						}
					});
				});
			});
		</script>
	</body>
</html>
