---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { 
	slug?: string;
	prev?: CollectionEntry<'blog'>;
	next?: CollectionEntry<'blog'>;
	wordCount?: number;
};




const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, tags, place, placeLabel, slug, prev, next, wordCount } = Astro.props;
const pageTitle = `${title} — ${SITE_TITLE}`;

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
	.filter(p => !p.data.draft && p.id !== slug) // exclude current post and drafts
	.filter(p => p.data.tags?.some(tag => tags?.includes(tag))) // at least one common tag
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()) // newest first
	.slice(0, 3); // limit to 3

const imageUrl = slug ? `/og/${slug}.png` : undefined;

const readingTime = wordCount ? Math.max(1, Math.round(wordCount / 200)) : undefined;

const shareUrl = Astro.url.toString();
const shareText = `Olha que prosa boa do seu Adi: "${title}"`;
const waUrl = `https://wa.me/?text=${encodeURIComponent(shareText + ' ' + shareUrl)}`;
const tgUrl = `https://t.me/share/url?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareText)}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageAbsolute = imageUrl ? new URL(imageUrl, canonicalURL).toString() : new URL('/og-home.png', canonicalURL).toString();

const blogPostingLD = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	"image": ogImageAbsolute,
	"datePublished": pubDate?.toISOString(),
	...(updatedDate && { "dateModified": updatedDate.toISOString() }),
	"author": {
		"@type": "Person",
		"name": "Adi Baldo",
		"url": new URL('/sobre', Astro.site).toString(),
		"sameAs": [
			"https://github.com/adibaldo"
		]
	},
	"publisher": {
		"@type": "Organization",
		"name": "Alfarrábios do Adi",
		"logo": {
			"@type": "ImageObject",
			"url": new URL('/favicon-adi.png', Astro.site).toString()
		}
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": canonicalURL.toString()
	},
	"inLanguage": "pt-BR",
	...(tags && tags.length > 0 && { "keywords": tags.join(", ") }),
	...(wordCount && { "wordCount": wordCount })
};

const breadcrumbLD = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Início",
			"item": Astro.site?.toString()
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Textos",
			"item": new URL('/blog', Astro.site).toString()
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": title
		}
	]
};
---

<html lang="pt-BR">
	<head>
		<BaseHead title={pageTitle} description={description} imageUrl={imageUrl} ogType="article" pubDate={pubDate} updatedDate={updatedDate} />
		<script type="application/ld+json" set:html={JSON.stringify(blogPostingLD).replace(/</g, '\\u003c')} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD).replace(/</g, '\\u003c')} />
	</head>
	<body>
		<a href="#main-content" class="skip-link">Ir ao conteúdo principal</a>
		<div id="progress-container">
			<div id="progress-bar"></div>
		</div>
		<Header />

		<main id="main-content" class="post" data-pagefind-body>
			<div class="reading-width">
				<nav aria-label="Breadcrumb" class="breadcrumb" style="font-size: 0.85rem; color: var(--text-muted, #666); margin-bottom: var(--space-md);">
					<a href="/" style="color: inherit; text-decoration: none;">Início</a>
					<span aria-hidden="true" style="margin: 0 0.5rem;">&rsaquo;</span>
					<a href="/blog" style="color: inherit; text-decoration: none;">Textos</a>
					<span aria-hidden="true" style="margin: 0 0.5rem;">&rsaquo;</span>
					<span aria-current="page" style="color: var(--text-main, #333);">{title}</span>
				</nav>

				<header class="post-header">
					<p class="post-meta">
						<span><FormattedDate date={pubDate} /></span>
						{(placeLabel || place) && <span>•</span>}
						{(placeLabel || place) && <span>{placeLabel || place}</span>}
						{tags && tags.length > 0 && <span>•</span>}
						{tags && tags.length > 0 && <a href={`/tags/${tags[0]}`} style="color: inherit; text-decoration: none;">{tags[0]}</a>}
						{readingTime && <span>•</span>}
						{readingTime && <span>{readingTime} min de prosa</span>}
					</p>
					<h1 class="post-title">{title}</h1>
					{updatedDate && (
						<p class="meta">
							Atualizado em <FormattedDate date={updatedDate} />
						</p>
					)}
				</header>

				{heroImage && (
					<div class="post-hero">
						<Image
							class="post-hero-image"
							width={1020}
							height={510}
							src={heroImage}
							alt={heroImageAlt || `Imagem de capa: ${title}`}
							widths={[400, 800, 1020]}
							sizes="(max-width: 620px) 100vw, (max-width: 1020px) 100vw, 1020px"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
				)}

				<article class="markdown-livro" data-url={canonicalURL.toString()}>
					<slot />
				</article>

				<section class="share-section" style="margin-top: var(--space-2xl);">
					<p class="meta" style="margin-bottom: var(--space-sm);">Compartilhe essa prosa:</p>
					<div style="display: flex; gap: var(--space-md);">
						<a class="icon-btn btn-whatsapp" href={waUrl} target="_blank" rel="noreferrer">
							<svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-11.7 8.38 8.38 0 0 1 3.8.9L21 3z"></path></svg>
							WhatsApp
						</a>
						<a class="icon-btn btn-telegram" href={tgUrl} target="_blank" rel="noreferrer">
							<svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
							Telegram
						</a>
					</div>
				</section>

				<nav class="pagination-nav" style="margin-top: var(--space-3xl); border-top: 1px solid var(--border-light); padding-top: var(--space-xl);">
					<div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg);">
						{prev ? (
							<a href={`/blog/${prev.id}/`} class="card" style="text-align: left;">
								<span class="meta">Anterior</span>
								<h4 class="card-title" style="font-size: 16px;">{prev.data.title}</h4>
							</a>
						) : <div />}
						{next ? (
							<a href={`/blog/${next.id}/`} class="card" style="text-align: right;">
								<span class="meta">Próxima</span>
								<h4 class="card-title" style="font-size: 16px;">{next.data.title}</h4>
							</a>
						) : <div />}
					</div>
				</nav>


				{relatedPosts.length > 0 && (
					<section class="related-posts" style="margin-top: var(--space-3xl); padding-top: var(--space-xl); border-top: 1px solid var(--border-light);">
						<h3 style="margin-bottom: var(--space-md);">Posts relacionados</h3>
						<div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-lg);">
							{relatedPosts.map(post => (
								<article class="card post-card" style="position: relative;">
									<a href={`/blog/${post.id}/`} style="position: absolute; inset: 0; z-index: 0;" aria-label={`Ler post: ${post.data.title}`}></a>
									<div class="post-thumb" style="aspect-ratio: 16 / 9; overflow: hidden; background: var(--tag-bg); border-bottom: 1px solid var(--border-light);">
										{post.data.heroImage ? (
											<Image
												src={post.data.heroImage}
												alt={post.data.heroImageAlt || `Capa do post ${post.data.title}`}
												widths={[400, 800]}
												sizes="(max-width: 620px) 100vw, 33vw"
												style="width: 100%; height: 100%; object-fit: cover;"
											/>
										) : (
											<div style="width: 100%; height: 100%; background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));" aria-hidden="true" />
										)}
									</div>
									<div class="post-card-body" style="padding: var(--space-md); position: relative; z-index: 1;">
										<h4 class="card-title" style="font-size: 1.1rem; margin-bottom: var(--space-xs);">
											<a href={`/blog/${post.id}/`} style="color: inherit; text-decoration: none;">{post.data.title}</a>
										</h4>
										<p class="meta" style="margin: 0; font-size: 0.85rem;">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</article>
							))}
						</div>
					</section>
				)}


				<hr style="margin: var(--space-3xl) 0;" />

				<Giscus />
			</div>
		</main>


		<script>
			const progressBar = document.getElementById('progress-bar');
			if (progressBar) {
				window.addEventListener('scroll', () => {
					const scrollTop = window.scrollY;
					const docHeight = document.documentElement.scrollHeight - window.innerHeight;
					const scrollPercent = (scrollTop / docHeight) * 100;
					progressBar.style.width = scrollPercent + '%';
				}, { passive: true });
			}
		</script>

		<Footer />

		<style>

			#progress-container {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 4px;
				z-index: 100;
				background: transparent;
				pointer-events: none;
			}

			#progress-bar {
				height: 100%;
				background: var(--accent-primary);
				width: 0%;
				transition: width 0.1s;
			}


			.post-hero {
				margin-bottom: var(--space-xl);
			}

			@media (max-width: 620px) {
				.post-hero {
					/* ligeiro recorte para antecipar início do texto em telas pequenas */
					aspect-ratio: 2.16 / 1;
					overflow: hidden;
					border-radius: var(--radius-card);
				}

				.post-hero :global(img) {
					width: 100%;
					height: 100%;
					object-fit: cover;
					border-radius: 0;
				}
			}
		</style>

	<style is:global>
		/* ─────────────────────────────────────────────────────────
		   TIPOGRAFIA LITERÁRIA DOS POSTS (markdown-livro)
		   Estética de livro clássico para leitura longa
		───────────────────────────────────────────────────────── */
		.markdown-livro {
			font-family: 'Merriweather', 'Georgia', 'Times New Roman', serif;
			line-height: 1.7;
			color: var(--text-primary);
			max-width: 68ch;
			margin: 0 auto;
			padding: 2rem 1rem;
			background-color: var(--bg-primary);
		}

		.markdown-livro h1,
		.markdown-livro h2,
		.markdown-livro h3 {
			text-align: center;
			color: var(--text-primary);
			font-weight: normal;
		}

		.markdown-livro h1 { font-size: 2.5rem; margin-bottom: 2rem; }
		.markdown-livro h2 { font-size: 1.8rem; margin-top: 3.5rem; margin-bottom: 0.2rem; }

		/* Metadado (data/local) logo após H2 */
		.markdown-livro h2 + p {
			text-align: center;
			font-style: italic;
			font-size: 0.95rem;
			color: var(--text-secondary);
			margin-top: 0;
			margin-bottom: 2.5rem;
			text-indent: 0;
		}

		/* Parágrafos estilo literário: justificado + recuo */
		.markdown-livro p {
			text-align: justify;
			margin-bottom: 0;
			text-indent: 2rem;
		}

		/* Primeiro parágrafo real (após metadado) sem recuo */
		.markdown-livro h2 + p + p { text-indent: 0; }

		/* Separadores de cena: --- vira * * * */
		.markdown-livro hr {
			border: none;
			text-align: center;
			margin: 3rem 0;
		}
		.markdown-livro hr::before {
			content: '* * *';
			font-size: 1.5rem;
			letter-spacing: 0.3rem;
			color: var(--text-muted);
		}

		/* Citações e poesias */
		.markdown-livro blockquote {
			margin: 2.5rem 3rem;
			padding-left: 1.5rem;
			border-left: 3px solid var(--border-light);
			font-style: italic;
			color: var(--text-secondary);
		}
		.markdown-livro blockquote p {
			text-align: left;
			text-indent: 0;
			margin-bottom: 0.5rem;
		}

		/* Imagens */
		.markdown-livro img {
			max-width: 100%;
			height: auto;
			display: block;
			margin: 3rem auto 0.5rem auto;
			border-radius: 4px;
			box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
		}

		/* Parágrafo que contém imagem: sem recuo, centralizado */
		.markdown-livro p:has(img) {
			text-indent: 0;
			text-align: center;
		}

		/* Itálico colado à imagem vira legenda */
		.markdown-livro img + em {
			display: block;
			text-align: center;
			font-size: 0.85rem;
			color: var(--text-muted);
			margin-bottom: 3rem;
		}

		/* Ajustes Mobile: telas < 480px para melhor legibilidade */
		@media (max-width: 480px) {
			.markdown-livro {
				padding: 1.5rem 0.5rem;
			}
			.markdown-livro p {
				text-indent: 1.25rem;
			}
			.markdown-livro blockquote {
				margin: 1.5rem 1rem;
				padding-left: 1rem;
			}
		}
	</style>
	</body>
</html>

	<style is:global>
		/* ─────────────────────────────────────────────────────────
		   MODO IMPRESSÃO (@media print)
		   Configurações adequadas para imprimir os textos
		───────────────────────────────────────────────────────── */
		@media print {
			@page {
				margin: 2cm 2.5cm;
				@bottom-right {
					content: counter(page);
				}
			}

			/* Ocultar elementos UI e de navegação */
			header,
			footer,
			.share-section,
			.pagination-nav,
			.breadcrumb,
			#progress-container,
			.related-posts,
			#giscus,
			hr {
				display: none !important;
			}

			/* Reset de background e cores */
			body, .markdown-livro {
				background-color: transparent !important;
				color: black !important;
				max-width: none !important;
				padding: 0 !important;
				margin: 0 !important;
			}

			/* Tipografia de livro no print */
			.markdown-livro {
				font-family: Georgia, 'Times New Roman', serif !important;
				line-height: 1.5;
			}

			/* Imagens devem aparecer e evitar quebrar ao meio */
			.markdown-livro img {
				print-color-adjust: exact;
				-webkit-print-color-adjust: exact;
				break-inside: avoid;
				page-break-inside: avoid;
				max-width: 100% !important;
			}

			/* Recuos de livro no parágrafo com espaçamento reduzido */
			.markdown-livro p {
				text-indent: 1.5em !important;
				margin-bottom: 0.3em !important;
			}

			/* Exceto o primeiro parágrafo depois do H2, ou parágrafo com imagem */
			.markdown-livro h2 + p,
			.markdown-livro p:has(img) {
				text-indent: 0 !important;
			}

			/* Quebra de página antes de H2 se houver muito conteúdo */
			.markdown-livro h2 {
				break-before: page;
				page-break-before: always;
				margin-top: 0 !important;
			}

			/* Mostrar URL atual no fim do texto */
			.markdown-livro::after {
				content: "Fonte: " attr(data-url);
				display: block;
				margin-top: 3cm;
				font-size: 0.85em;
				text-align: center;
				color: #555;
				font-style: italic;
			}
		}
	</style>
